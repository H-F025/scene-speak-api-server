{
  "family": "${PROJECT}-${ENV}-migrate",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "executionRoleArn": "${ECS_EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${ECS_TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "migrate",
      "image": "${APP_ECR_ACCOUNT_URL}/${PROJECT}/${ENV}/migration:${SHA1}",
      "essential": true,
      "command": ["php", "artisan", "migrate", "--force"],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${PROJECT}-${ENV}-migrate",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "migrate"
        }
      },
      "environment": [
        {
          "name": "APP_NAME",
          "value": "SceneSpeak"
        },
        {
          "name": "APP_ENV",
          "value": "production"
        },
        {
          "name": "APP_URL",
          "value": "https://${APP_DOMAIN}"
        },
        {
          "name": "APP_DEBUG",
          "value": "false"
        },
        {
          "name": "APP_LOCALE",
          "value": "ja"
        },
        {
          "name": "APP_FALLBACK_LOCALE",
          "value": "ja"
        },
        {
          "name": "LOG_CHANNEL",
          "value": "stderr"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "DB_CONNECTION",
          "value": "mysql"
        },
        {
          "name": "DB_HOST",
          "value": "${DB_HOST}"
        },
        {
          "name": "DB_PORT",
          "value": "3306"
        },
        {
          "name": "DB_USERNAME",
          "value": "${DB_USERNAME}"
        },
        {
          "name": "DB_DATABASE",
          "value": "${DB_DATABASE}"
        }
      ],
      "secrets": [
        {
          "name": "APP_KEY",
          "valueFrom": "$APP_KEY_ARN"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "$DB_PASSWORD_ARN"
        }
      ]
    }
  ]
}