{
  "family": "${PROJECT}-${ENV}-app",
  "networkMode": "awsvpc",
  "cpu": "${APP_CPU}",
  "memory": "${APP_MEMORY}",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "executionRoleArn": "${ECS_EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${ECS_TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "nginx",
      "image": "${APP_ECR_ACCOUNT_URL}/${PROJECT}/${ENV}/nginx:${SHA1}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80
        }
      ],
      "stopTimeout": 120,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${PROJECT}-${ENV}-nginx",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "nginx"
        }
      }
    },
    {
      "name": "app",
      "image": "${APP_ECR_ACCOUNT_URL}/${PROJECT}/${ENV}/app:${SHA1}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9000,
          "hostPort": 9000
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${PROJECT}-${ENV}-app",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "app"
        }
      },
      "environment": [
        {
          "name": "APP_NAME",
          "value": "SceneSpeak"
        },
        {
          "name": "APP_ENV",
          "value": "production"
        },
        {
          "name": "APP_URL",
          "value": "https://api.${APP_DOMAIN}"
        },
        {
          "name": "APP_DOMAIN",
          "value": "api.${APP_DOMAIN}"
        },
        {
          "name": "APP_DEBUG",
          "value": "false"
        },
        {
          "name": "APP_LOCALE",
          "value": "ja"
        },
        {
          "name": "APP_FALLBACK_LOCALE",
          "value": "ja"
        },
        {
          "name": "LOG_CHANNEL",
          "value": "stderr"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "AWS_DEFAULT_REGION",
          "value": "ap-northeast-1"
        },
        {
          "name": "DB_CONNECTION",
          "value": "mysql"
        },
        {
          "name": "DB_HOST",
          "value": "${DB_HOST}"
        },
        {
          "name": "DB_PORT",
          "value": "3306"
        },
        {
          "name": "DB_USERNAME",
          "value": "${DB_USERNAME}"
        },
        {
          "name": "DB_DATABASE",
          "value": "${DB_DATABASE}"
        },
        {
          "name": "BROADCAST_CONNECTION",
          "value": "log"
        },
        {
          "name": "QUEUE_CONNECTION",
          "value": "database"
        },
        {
          "name": "CACHE_STORE",
          "value": "database"
        },
        {
          "name": "SESSION_DRIVER",
          "value": "database"
        },
        {
          "name": "SESSION_LIFETIME",
          "value": "120"
        },
        {
          "name": "SESSION_SECURE_COOKIE",
          "value": "true"
        },
        {
          "name": "SESSION_DOMAIN",
          "value": ".${APP_DOMAIN}"
        },
        {
          "name": "SANCTUM_STATEFUL_DOMAINS",
          "value": "${APP_FRONT_DOMAIN}"
        }
      ],
      "secrets": [
        {
          "name": "APP_KEY",
          "valueFrom": "$APP_KEY_ARN"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "$DB_PASSWORD_ARN"
        }
      ]
    }
  ]
}